generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  phone     String?  @unique
  name      String
  role      String   @default("PARTY") // PARTY | EXPERT | ADMIN
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicantCases     Case[]              @relation("ApplicantCases")
  respondentCases    Case[]              @relation("RespondentCases")
  parties            Party[]
  uploadedDocuments  Document[]          @relation("UploadedBy")
  expertProfile      Expert?
  sentMessages       Message[]           @relation("SentBy")
  receivedMessages   Message[]           @relation("ReceivedBy")
  auditLogs          AuditLog[]
  adrAssessments     ADRAssessment[]
  caseResponses      CaseResponse[]      @relation("ResponseBy")
  expertApplications ExpertApplication[] @relation("Applicant")
  reviewedApplications ExpertApplication[] @relation("Reviewer")
  conflictOfInterests  ConflictOfInterest[] @relation("PartyConflicts")
  expertRatings      ExpertRating[]      @relation("Rater")
}

model Case {
  id              String    @id @default(cuid())
  caseNumber      String    @unique // ED-2026-001
  patentNumber    String
  patentTitle     String
  disputeType     String // INFRINGEMENT | VALUATION | LICENSING | OTHER
  amountInDispute Float?
  description     String?
  status          String    @default("DRAFT") // DRAFT | SUBMITTED | RESPONDENT_PENDING | RESPONDENT_REJECTED | COUNTERCLAIM_PENDING | ACCEPTED | EXPERT_ASSIGNING | IN_EVALUATION | DETERMINATION_ISSUED | COMPLETED | CLOSED
  applicantId     String
  respondentId    String?
  responseDeadline DateTime?
  responseAction  String?   // ACCEPT | REJECT | COUNTERCLAIM
  adrAssessmentId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  applicant       User                @relation("ApplicantCases", fields: [applicantId], references: [id])
  respondent      User?               @relation("RespondentCases", fields: [respondentId], references: [id])
  adrAssessment   ADRAssessment?      @relation(fields: [adrAssessmentId], references: [id])
  parties         Party[]
  documents       Document[]
  assignments     ExpertAssignment[]
  aiAnalyses      AIAnalysis[]
  determinations  Determination[]
  caseResponse    CaseResponse?
  eneAssessments  ENEAssessment[]
  expertRatings   ExpertRating[]
  messages        Message[]           @relation("CaseMessages")
}

model Party {
  id          String   @id @default(cuid())
  userId      String
  caseId      String
  role        String // APPLICANT | RESPONDENT
  company     String?
  contactInfo String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([userId, caseId])
}

model Document {
  id         String   @id @default(cuid())
  caseId     String
  uploaderId String
  fileName   String
  filePath   String
  fileType   String // pdf | doc | docx | jpg | png
  fileSize   Int
  category   String // PATENT_CERTIFICATE | CLAIMS | EVIDENCE | TECHNICAL_DESCRIPTION | INFRINGEMENT_EVIDENCE | OTHER
  uploadTime DateTime @default(now())

  case     Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploader User @relation("UploadedBy", fields: [uploaderId], references: [id])
}

model Expert {
  id                String   @id @default(cuid())
  userId            String   @unique
  name              String
  technicalFields   String // JSON array
  qualifications    String?
  availability      String   @default("AVAILABLE") // AVAILABLE | BUSY | UNAVAILABLE
  hourlyRate        Float?
  bio               String?
  panelCategory     String?  // ELECTRONICS | SOFTWARE | MECHANICAL | CHEMICAL | PHARMACEUTICAL | OTHER
  averageRating     Float?   @default(0)
  totalRatings      Int      @default(0)
  applicationStatus String?  // null (seed) | PENDING | APPROVED | REJECTED
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User                @relation(fields: [userId], references: [id])
  assignments       ExpertAssignment[]
  determinations    Determination[]
  eneAssessments    ENEAssessment[]
  conflictOfInterests ConflictOfInterest[] @relation("ExpertConflicts")
  ratings           ExpertRating[]
}

model ExpertAssignment {
  id                String    @id @default(cuid())
  caseId            String
  expertId          String
  assignedAt        DateTime  @default(now())
  status            String    @default("PENDING") // PENDING | ACCEPTED | DECLINED | COMPLETED
  declarationSigned Boolean   @default(false)
  declarationSignedAt DateTime?

  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  expert Expert @relation(fields: [expertId], references: [id])

  @@unique([caseId, expertId])
}

model AIAnalysis {
  id           String    @id @default(cuid())
  caseId       String
  analysisType String // CLAIM_INTERPRETATION | INFRINGEMENT_COMPARISON | VALUATION
  status       String    @default("PENDING") // PENDING | PROCESSING | COMPLETED | FAILED
  result       String? // JSON blob
  error        String?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  case Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model Determination {
  id                String    @id @default(cuid())
  caseId            String
  expertId          String
  type              String // INTERIM | FINAL
  content           String
  issuedAt          DateTime  @default(now())
  correctedAt       DateTime?
  correctionContent String?

  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  expert Expert @relation(fields: [expertId], references: [id])
}

model Message {
  id         String    @id @default(cuid())
  fromUserId String
  toUserId   String
  caseId     String?
  content    String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  from User  @relation("SentBy", fields: [fromUserId], references: [id])
  to   User  @relation("ReceivedBy", fields: [toUserId], references: [id])
  case Case? @relation("CaseMessages", fields: [caseId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  targetType String // CASE | USER | EXPERT | DOCUMENT | DETERMINATION
  targetId   String
  details    String? // JSON blob
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ============================================================
// 新增模型
// ============================================================

model ADRAssessment {
  id                  String    @id @default(cuid())
  userId              String?
  disputeType         String    // INFRINGEMENT | VALUATION | LICENSING | OTHER
  hasPatent           Boolean   @default(true)
  patentNumber        String?
  bothPartiesKnown    Boolean   @default(false)
  respondentWilling   String?   // YES | NO | UNKNOWN
  amountInDispute     String?   // UNDER_100W | RANGE_100W_500W | RANGE_500W_1M | OVER_1M
  urgencyLevel        String?   // LOW | MEDIUM | HIGH
  hasPriorNegotiation Boolean   @default(false)
  technicalComplexity String?   // LOW | MEDIUM | HIGH
  recommendedPath     String    // EXPERT_EVALUATION | ENE | MEDIATION | ARBITRATION
  answers             String?   // JSON blob of all Q&A
  createdAt           DateTime  @default(now())

  user  User?  @relation(fields: [userId], references: [id])
  cases Case[]
}

model CaseResponse {
  id               String   @id @default(cuid())
  caseId           String   @unique
  respondentId     String
  action           String   // ACCEPT | REJECT | COUNTERCLAIM
  responseText     String?
  counterclaimDesc String?
  respondedAt      DateTime @default(now())

  case       Case @relation(fields: [caseId], references: [id], onDelete: Cascade)
  respondent User @relation("ResponseBy", fields: [respondentId], references: [id])
}

model ENEAssessment {
  id                String    @id @default(cuid())
  caseId            String
  expertId          String
  scope             String    // INFRINGEMENT_ONLY | VALUATION_ONLY | FULL
  bindingType       String    @default("NON_BINDING") // BINDING | NON_BINDING
  applicantAgreed   Boolean   @default(false)
  respondentAgreed  Boolean   @default(false)
  bothPartiesAgreed Boolean   @default(false)
  content           String?
  preliminaryOpinion String?
  status            String    @default("DRAFT") // DRAFT | PENDING_AGREEMENT | IN_PROGRESS | OPINION_ISSUED | COMPLETED
  issuedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  case   Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  expert Expert @relation(fields: [expertId], references: [id])
}

model ExpertApplication {
  id                String    @id @default(cuid())
  userId            String    @unique
  name              String
  email             String
  phone             String?
  company           String?
  technicalFields   String    // JSON array
  qualifications    String?
  experienceYears   Int?
  bio               String?
  hourlyRateExpect  Float?
  status            String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewNote        String?
  reviewedBy        String?
  reviewedAt        DateTime?
  createdAt         DateTime  @default(now())

  user     User  @relation("Applicant", fields: [userId], references: [id])
  reviewer User? @relation("Reviewer", fields: [reviewedBy], references: [id])
}

model ExpertRating {
  id         String   @id @default(cuid())
  expertId   String
  caseId     String
  raterId    String
  score      Int      // 1-5
  comment    String?
  dimensions String?  // JSON: {professionalism: 5, fairness: 4, timeliness: 3, expertise: 5}
  createdAt  DateTime @default(now())

  expert Expert @relation(fields: [expertId], references: [id])
  case   Case   @relation(fields: [caseId], references: [id])
  rater  User   @relation("Rater", fields: [raterId], references: [id])

  @@unique([expertId, caseId, raterId])
}

model ConflictOfInterest {
  id          String   @id @default(cuid())
  expertId    String
  partyUserId String
  reason      String   // SAME_COMPANY | PRIOR_REPRESENTATION | FAMILY | FINANCIAL | OTHER
  details     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expert    Expert @relation("ExpertConflicts", fields: [expertId], references: [id])
  partyUser User   @relation("PartyConflicts", fields: [partyUserId], references: [id])

  @@unique([expertId, partyUserId])
}
